# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=asms_db

# ── Auth Service ──────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_here_min_32_chars
JWT_REFRESH_SECRET=generate_another_long_random_refresh_string_here_min_32_chars

# ── Academic Service (Django) ─────────────────────────────────────────────────
DJANGO_SECRET_KEY=generate_a_long_random_django_secret_key_here

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────────────────────
# Leave blank to fall back to console mock
SMTP_USER=
SMTP_PASS=

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Leave blank to fall back to console mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=