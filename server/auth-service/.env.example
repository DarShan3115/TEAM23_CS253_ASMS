# ─── Auth Service Environment Variables ───────────────────────────────────────

PORT=5001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db:5432/asms_db

# ── JWT Secrets (use long random strings in production) ────────────────────────
JWT_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_another_long_random_string_here

# ── Email / Nodemailer (Gmail SMTP) ────────────────────────────────────────────
# Use a Gmail App Password — NOT your main Gmail password.
# Guide: https://support.google.com/accounts/answer/185833
SMTP_USER=noreply@iitk.ac.in
SMTP_PASS=your_gmail_app_password_here

# ── SMS / Twilio ───────────────────────────────────────────────────────────────
# Get credentials from https://console.twilio.com/
# TWILIO_PHONE must be in E.164 format: +1XXXXXXXXXX or +91XXXXXXXXXX
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=+1XXXXXXXXXX

# ── App Mode ──────────────────────────────────────────────────────────────────
# Set to 'production' to enable secure cookies
NODE_ENV=development